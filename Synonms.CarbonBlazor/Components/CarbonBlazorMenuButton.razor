@if (_isOpen)
{
    <div class="cb-menu-backdrop" @onclick="Close"></div>
}

<div class="cb-menu-button-wrapper @CarbonBlazorMenuItemSizeMapper.ToClass(Size)">
    <button class="@GetButtonClass()"
            type="button"
            aria-haspopup="true"
            aria-expanded="@_isOpen"
            disabled="@IsDisabled"
            @onclick="Toggle">
        @Label
        @((MarkupString)CarbonBlazorIconMapper.ToSvg(CarbonBlazorIcon.ChevronDown, 16))
    </button>
    <CascadingValue Name="CloseMenu" Value="_closeMenuAction">
        <CarbonBlazorMenu Size="@Size" IsOpen="@_isOpen">
            @Items
        </CarbonBlazorMenu>
    </CascadingValue>
</div>

@code {
    private bool _isOpen;
    private Action _closeMenuAction = null!;

    [Parameter]
    [EditorRequired]
    public string Label { get; set; } = string.Empty;

    [Parameter]
    public CarbonBlazorButtonKind Kind { get; set; } = CarbonBlazorButtonKind.Primary;

    [Parameter]
    public CarbonBlazorMenuItemSize Size { get; set; } = CarbonBlazorMenuItemSize.Medium;

    [Parameter]
    public bool IsDisabled { get; set; }

    [Parameter]
    [EditorRequired]
    public RenderFragment Items { get; set; } = null!;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        _closeMenuAction = Close;
    }

    private string GetButtonClass()
    {
        const string baseClass = "cb-menu-button-trigger";
        string kindClass = CarbonBlazorButtonKindMapper.ToClass(Kind);
        string sizeClass = CarbonBlazorMenuItemSizeMapper.ToClass(Size);

        return CssClasses.Concatenate(baseClass, kindClass, sizeClass);
    }

    private void Toggle()
    {
        _isOpen = !_isOpen;
    }

    private void Close()
    {
        _isOpen = false;
    }
}
